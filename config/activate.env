# ORION — Alle Pfade und Hosts
# cd /workspace && source config/activate.env

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export ORION_DATA_DIR="${ORION_DATA_DIR:-$ROOT/data}"
export ORION_CAUSAL_HOME="${ORION_CAUSAL_HOME:-$ROOT/CausalHome}"
export ORION_API_HOST="${ORION_API_HOST:-0.0.0.0}"
export ORION_API_PORT="${ORION_API_PORT:-8765}"
export ORION_OLLAMA_HOST="${ORION_OLLAMA_HOST:-localhost}"
export ORION_OLLAMA_PORT="${ORION_OLLAMA_PORT:-11434}"
export ORION_OLLAMA_BASE="${ORION_OLLAMA_BASE:-http://localhost:11434}"
export ORION_MILVUS_HOST="${ORION_MILVUS_HOST:-localhost}"
export ORION_MILVUS_PORT="${ORION_MILVUS_PORT:-19530}"
export PYTHONPATH="${PYTHONPATH:-$ROOT/src}"
