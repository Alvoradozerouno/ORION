# GENESIS SOVEREIGN FABRIC — Secure Config Example
# Copy to .env. Never commit .env.

# API
GSF_PORT=8765
GSF_DATA_PATH=/app/data/gsf.db

# Signing (64 hex chars = 32 bytes)
# Generate: openssl rand -hex 32
GSF_SIGNING_KEY=

# Logging
RUST_LOG=info

# Optional: OpenAI Adapter
# OPENAI_API_KEY=
# GSF_OPENAI_MODEL=gpt-4o-mini
